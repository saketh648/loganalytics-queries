{
    "type": "object",
    "properties": {
        "DatafactoryName": { "type": "string" },
        "NotificationPipeline": { "type": "string" },
        "SourcePipelineName": { "type": "string" },
        "RunId": { "type": "string" },
        "ExecutionTime": { "type": "string" },
        "TeamName": { "type": "string" },
        "Status": { "type": "string" },
        "Message": { "type": "string" },
        "Recipients": { "type": "string" }
    }
}



<div style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 700px; margin: auto; background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden;">
  
  <div style="background-color: #0078D4; padding: 15px 20px; color: white;">
    <h2 style="margin:0; font-size: 20px;">ADF Pipeline Execution Notification</h2>
  </div>

  <div style="padding: 20px;">
    <p style="font-size: 16px;">
      <strong>Status:</strong> 
      <span style="color: @{if(equals(triggerBody()?['Status'], 'Success'), '#107C10', '#A80000')}; font-weight: bold;">
        @{triggerBody()?['Status']}
      </span>
    </p>

    <table style="width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px;">
      <tr style="background-color: #f4f4f4;">
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold; width: 35%;">Source Pipeline</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd;">@{triggerBody()?['SourcePipelineName']}</td>
      </tr>
      <tr>
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold;">Team Name</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd;">@{triggerBody()?['TeamName']}</td>
      </tr>
      <tr style="background-color: #f4f4f4;">
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold;">Data Factory Name</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd;">@{triggerBody()?['DatafactoryName']}</td>
      </tr>
      <tr>
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold;">Run ID</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-family: monospace;">@{triggerBody()?['RunId']}</td>
      </tr>
      <tr style="background-color: #f4f4f4;">
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold;">Execution Time</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd;">@{triggerBody()?['ExecutionTime']}</td>
      </tr>
      <tr>
        <td style="padding: 8px 12px; border: 1px solid #ddd; font-weight: bold;">Message</td>
        <td style="padding: 8px 12px; border: 1px solid #ddd;">@{triggerBody()?['Message']}</td>
      </tr>
    </table>
  </div>
</div>




[@{triggerBody()?['Status']}] ADF Pipeline Notification - @{triggerBody()?['SourcePipelineName']}

