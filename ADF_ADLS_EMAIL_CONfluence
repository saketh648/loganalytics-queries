import json
import pandas as pd

# Load the local JSON file
file_path = "your_file.json"

try:
    with open(file_path, 'r') as f:
        data = json.load(f)
    
    # Convert to a Pandas DataFrame for easy analysis
    df = pd.DataFrame(data)
    
    print(f"📊 Total Records in File: {len(df)}")
    
    # 1. Check for completely identical rows
    duplicate_rows = df.duplicated().sum()
    print(f"🔄 Exact Duplicate Rows: {duplicate_rows}")
    
    # 2. Check for specific ID duplicates (e.g., event_id or player_id)
    # Replace 'event_id' with whatever your unique identifier key is called
    if 'event_id' in df.columns:
        total_ids = len(df['event_id'])
        unique_ids = df['event_id'].nunique()
        print(f"🔑 Total IDs: {total_ids} | Unique IDs: {unique_ids}")
        print(f"⚠️ Duplicate ID Count: {total_ids - unique_ids}")
        
        # Show top duplicated IDs
        print("\n🔥 Top Duplicated Records:")
        print(df['event_id'].value_counts().head(5))
        
except Exception as e:
    print(f"Error processing file: {e}")
    print("If it's an NDJSON (JSON Lines) file, try reading line-by-line instead.")
