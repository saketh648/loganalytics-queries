{
    "definition": {
        "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
        "contentVersion": "1.0.0.0",
        "actions": {
            "Send_an_email_(V2)": {
                "type": "ApiConnection",
                "inputs": {
                    "host": {
                        "connection": {
                            "referenceName": "office365"
                        }
                    },
                    "method": "post",
                    "body": {
                        "To": "@triggerBody()?['Recipients']",
                        "Subject": "[@{triggerBody()?['Status']}] ADF Pipeline Notification - @{triggerBody()?['SourcePipelineName']}",
                        "Body": "<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 650px; margin: auto; border: 1px solid #d0d0d0; border-radius: 6px; overflow: hidden;\"><div style=\"background-color: #0078D4; padding: 14px 20px; color: white;\"><h2 style=\"margin:0; font-size: 18px;\">ADF Pipeline Execution Details</h2></div><div style=\"padding: 20px;\"><p style=\"font-size: 15px; margin-top: 0;\"><strong>Status:</strong> <span style=\"color: @{if(equals(triggerBody()?['Status'], 'Success'), '#107C10', '#A80000')}; font-weight: bold;\">@{triggerBody()?['Status']}</span></p><table style=\"width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 13px;\"><tr style=\"background-color: #f8f8f8;\"><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold; width: 35%;\">Source Pipeline</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0;\">@{triggerBody()?['SourcePipelineName']}</td></tr><tr><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold;\">Team Name</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0;\">@{triggerBody()?['TeamName']}</td></tr><tr style=\"background-color: #f8f8f8;\"><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold;\">Data Factory Name</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0;\">@{triggerBody()?['DatafactoryName']}</td></tr><tr><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold;\">Run ID</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-family: monospace;\">@{triggerBody()?['RunId']}</td></tr><tr style=\"background-color: #f8f8f8;\"><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold;\">Execution Time</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0;\">@{triggerBody()?['ExecutionTime']}</td></tr><tr><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0; font-weight: bold;\">Message</td><td style=\"padding: 8px 10px; border: 1px solid #e0e0e0;\">@{triggerBody()?['Message']}</td></tr></table></div></div>",
                        "Importance": "Normal"
                    },
                    "path": "/v2/Mail"
                },
                "runAfter": {}
            }
        },
        "outputs": {},
        "triggers": {
            "When_an_HTTP_request_is_received": {
                "type": "Request",
                "kind": "Http",
                "inputs": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "DatafactoryName": {
                                "type": "string"
                            },
                            "NotificationPipeline": {
                                "type": "string"
                            },
                            "SourcePipelineName": {
                                "type": "string"
                            },
                            "RunId": {
                                "type": "string"
                            },
                            "ExecutionTime": {
                                "type": "string"
                            },
                            "TeamName": {
                                "type": "string"
                            },
                            "Status": {
                                "type": "string"
                            },
                            "Message": {
                                "type": "string"
                            },
                            "Recipients": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "kind": "stateful"
    }
}
