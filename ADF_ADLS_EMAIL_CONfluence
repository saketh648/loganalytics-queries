import json
from collections import Counter

# Update this to match your local filename exactly
file_path = "your_file.json"

print("⏳ Reading and parsing file... please wait...")

try:
    # Try reading as a standard single JSON array/file
    with open(file_path, "r") as f:
        data = json.load(f)
except json.JSONDecodeError:
    # If that fails, read it as a JSON Lines / NDJSON file (line-by-line)
    data = []
    with open(file_path, "r") as f:
        for line in f:
            if line.strip():
                data.append(json.loads(line))

# Handle list of records
if isinstance(data, list):
    total_records = len(data)
    print(f"\n📊 Total Records in File: {total_records}")
    
    # Let's count keys to check for duplicates
    # Replace 'player_id' or 'event_id' with whatever unique key your data uses
    target_id_key = "player_id" 
    
    ids = [str(record.get(target_id_key)) for record in data if target_id_key in record]
    
    if ids:
        id_counts = Counter(ids)
        unique_ids = len(id_counts)
        print(f"🔑 Unique {target_id_key}s found: {unique_ids}")
        
        # Check if the same ID shows up an absurd number of times
        print(f"\n🔥 Top Duplicated {target_id_key}s:")
        for item, count in id_counts.most_common(5):
            print(f"   ID: {item} -> appears {count} times")
    else:
        print(f"\n⚠️ Note: Key '{target_id_key}' not found in the records.")
        # Print keys of the first record so you can see what fields exist
        if total_records > 0:
            print(f"Available keys in your data: {list(data[0].keys())}")
else:
    print("The JSON file is a single dictionary block, not a list of records.")
